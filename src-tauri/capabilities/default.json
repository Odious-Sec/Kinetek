{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities granted to Kinetek's main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:webview:allow-create-webview-window",

    "dialog:default",

    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "code", "cmd": "code", "args": true, "sidecar": false },
        { "name": "npm", "cmd": "npm", "args": true, "sidecar": false },
        { "name": "npx", "cmd": "npx", "args": true, "sidecar": false },
        { "name": "dotnet", "cmd": "dotnet", "args": true, "sidecar": false }
      ]
    },

    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://generativelanguage.googleapis.com/*" },
        { "url": "https://api.groq.com/*" },
        { "url": "https://openrouter.ai/*" },
        { "url": "https://api.anthropic.com/*" },
        { "url": "https://api.openai.com/*" },
        { "url": "https://api.github.com/*" }
      ]
    }
  ]
}
